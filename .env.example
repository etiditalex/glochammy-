# =============================================================================
# Next.js does NOT load this file — it is only a template for humans.
# Copy to .env.local and put real values there (see https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables)
#
#   Windows (PowerShell): Copy-Item .env.example .env.local
#   Then edit .env.local — never commit .env.local (it is gitignored).
# =============================================================================

# No space after "="

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_from_supabase_api_settings

# Optional duplicates (same values); helps server/middleware read env at runtime
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_anon_key

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase service role (server-only). Required for M-Pesa STK callback to mark orders paid (RLS).
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Safaricom Daraja — Lipa Na M-Pesa Online (STK). See https://developer.safaricom.co.ke
# Use sandbox credentials until you go live. Callback must be HTTPS in production.
# MPESA_USE_SANDBOX=true
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=174379
# MPESA_PARTY_B=174379
# MPESA_PASSKEY=
# MPESA_CALLBACK_URL=https://YOUR_VERCEL_DOMAIN/api/mpesa/stk-callback
# MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# For Buy Goods / Till use: CustomerBuyGoodsOnline

# Resend (optional)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Glochammy <onboarding@resend.dev>
