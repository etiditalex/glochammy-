# =============================================================================
# Next.js does NOT load this file — it is only a template for humans.
# Copy to .env.local and put real values there (see https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables)
#
#   Windows (PowerShell): Copy-Item .env.example .env.local
#   Then edit .env.local — never commit .env.local (it is gitignored).
# =============================================================================

# No space after "="

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_from_supabase_api_settings

# Optional duplicates (same values); helps server/middleware read env at runtime
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_anon_key

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase service role (server-only). Required for the STK *callback* to auto-mark orders paid,
# and for Admin → Team & accounts (create staff/customer logins).
# STK push on the cart still works without this; orders stay pending until you set this or update Admin.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Safaricom Daraja — online M-Pesa payments (STK Push).
# Fill these in .env.local to enable "Pay with M-Pesa" on cart checkout (KES only).
# Callback URL must be HTTPS in production and registered in your Daraja app.
# MPESA_BASE_URL=https://api.safaricom.co.ke
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=174379
# MPESA_PASSKEY=
# MPESA_PARTY_B=174379
# MPESA_CALLBACK_URL=https://YOUR_VERCEL_DOMAIN/api/daraja/callback
# MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# MPESA_OAUTH_URL=https://api.safaricom.co.ke/oauth/v1/generate?grant_type=client_credentials
# MPESA_STKPUSH_URL=https://api.safaricom.co.ke/mpesa/stkpush/v1/processrequest
# MPESA_STKPUSH_QUERY_URL=https://api.safaricom.co.ke/mpesa/stkpushquery/v1/query
#
# Optional Daraja endpoints for future payout/ops integrations:
# MPESA_B2C_URL=https://api.safaricom.co.ke/mpesa/b2c/v1/paymentrequest
# MPESA_TRANSACTION_STATUS_URL=https://api.safaricom.co.ke/mpesa/transactionstatus/v1/query
# MPESA_ACCOUNT_BALANCE_URL=https://api.safaricom.co.ke/mpesa/accountbalance/v1/query
# MPESA_B2C_SECURITY_CREDENTIAL=
#
# Legacy fallback still supported:
# MPESA_USE_SANDBOX=true

# Resend (optional — welcome mail + admin “Email” broadcasts)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Glochammy <onboarding@resend.dev>
